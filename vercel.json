{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.culoca.com" }
      ],
      "destination": "https://culoca.com/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "src/routes/api/**/*": {
      "includeFiles": "node_modules/{sharp,@img/sharp-linux-x64,@img/sharp-libvips-linux-x64}/**/*"
    }
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install --include=optional",
  "framework": "sveltekit"
} 
