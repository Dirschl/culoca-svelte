# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (server-only; never commit real values). Set in deployment env.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Hetzner WebDAV Configuration (Optional - for original file backup)
HETZNER_WEBDAV_URL=https://your-hetzner-webdav-url.com
HETZNER_WEBDAV_USER=your_username
HETZNER_WEBDAV_PASSWORD=your_password
HETZNER_WEBDAV_PUBLIC_URL=https://your-public-url.com

# Image Quality Settings
# Format: 'jpg' or 'webp'
# Quality: 1-100 (higher = better quality, larger file size)

# 2048px images (main display)
IMAGE_FORMAT_2048=jpg
IMAGE_QUALITY_2048=85

# 512px images (gallery thumbnails)
IMAGE_FORMAT_512=jpg
IMAGE_QUALITY_512=85

# 64px images (map markers)
IMAGE_FORMAT_64=jpg
IMAGE_QUALITY_64=85

# Adobe Affiliate (Partnerize): Basis-URL für Klicks zu Adobe Stock (optional).
# PUBLIC_ADOBE_AFFILIATE_REDIRECT_BASE=https://prf.hn/click/camref:1011lXXXXX/destination

# Culoca Bildverkauf (Lemon Squeezy) — server-only
CULOCA_SALES_ENABLED=false
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_STANDARD_ID=
LEMONSQUEEZY_VARIANT_EXTENDED_ID=
LEMONSQUEEZY_TEST_MODE=true
CULOCA_LICENSE_STANDARD_PRICE_CENTS=2900
CULOCA_LICENSE_EXTENDED_PRICE_CENTS=9900

# Culoca Bildverkauf — client (Preisanzeige, Feature-Flag)
PUBLIC_CULOCA_SALES_ENABLED=false
PUBLIC_CULOCA_LICENSE_STANDARD_PRICE_CENTS=2900
PUBLIC_CULOCA_LICENSE_EXTENDED_PRICE_CENTS=9900
